# ══════════════════════════════════════════════════════════════
#  VOID Platform — Production Environment
#  Copy this to .env and fill in every value before deploying
# ══════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Database (from Railway/Render PostgreSQL) ─────────────────
DATABASE_URL=postgresql://user:password@host:5432/void_platform
DB_HOST=your-db-host
DB_PORT=5432
DB_NAME=void_platform
DB_USER=your-db-user
DB_PASSWORD=your-db-password

# ── JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ──
JWT_ACCESS_SECRET=generate_a_64_byte_random_hex_string_here
JWT_REFRESH_SECRET=generate_a_different_64_byte_random_hex_string_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ── URLs ──────────────────────────────────────────────────────
FRONTEND_URL=https://yourdomain.com
INVITE_BASE_URL=https://yourdomain.com/invite
BASE_URL=https://api.yourdomain.com

# ── File Uploads ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm,audio/mpeg,audio/ogg,application/pdf

# ── AI ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
AI_USER_ID=00000000-0000-0000-0000-000000000001

# ── Monetization ──────────────────────────────────────────────
VOID_PLATFORM_FEE_PERCENT=5
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
